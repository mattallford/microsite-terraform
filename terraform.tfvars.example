# Example variable values — copy to terraform.tfvars (git-ignored) for local use,
# or supply values through Octopus Deploy variable substitution in the pipeline.
#
# Naming convention for storage_account_name:
#   st + <microsite-type> + <identifier>
#
#   <microsite-type> is one of: devops | blog | docs | int | handbook
#   <identifier>     is either a PR number (e.g. pr42) for short-lived preview
#                    environments, or "main" for the long-lived production
#                    environment.
#
#   Examples:
#     stdevopspr42   — PR #42 preview of the DevOps microsite
#     stdevopsmain   — Production DevOps microsite
#     stblogpr7      — PR #7 preview of the Blog microsite
#     sthandbookmain — Production Handbook microsite

storage_account_name = "stdevopspr42"
resource_group_name  = "microsites-preprod"
location             = "westus"
